--Window Functions
--Find latest order per customer
SELECT* FROM(
   SELECT
CUSTOMER_NAME,PRODUCT_NAME, ORDER_DATE,
      ROW_NUMBER() OVER (PARTITION BY CUSTOMER_NAME ORDER BY ORDER_DATE DESC) AS RN
      FROM SOURCE_ORDERS) AS T 
      WHERE RN =1;

--Rank customers by total spending
     SELECT CUSTOMER_NAME, SUM(AMOUNT) AS TOTAL_AMOUNT,
     RANK() OVER (ORDER BY TOTAL_AMOUNT DESC) AS RANK
    FROM SOURCE_ORDERS
    GROUP BY CUSTOMER_NAME;

 --Find second highest order amount
 SELECT AMOUNT
 FROM( 
     SELECT AMOUNT,
     DENSE_RANK() OVER (ORDER BY AMOUNT DESC)AS DR
     FROM SOURCE_ORDERS
 )AS T
 WHERE DR = 2;

--Show running total of revenue by order date
 SELECT ORDER_DATE,
       AMOUNT,
       SUM(AMOUNT) OVER(ORDER BY ORDER_DATE) AS RUNNING_TOTAL
FROM SOURCE_ORDERS;

 
