--Get all orders with only date (not time)
SELECT ORDER_ID, CUSTOMER_NAME, DATE(CURRENT_DATE) AS ORDER_DATE
FROM SOURCE_ORDERS;

--Get all orders with only time(not date)
SELECT CUSTOMER_ID,CUSTOMER_NAME, TO_TIME(ORDER_DATE) AS ORDER_TIME
FROM SOURCE_ORDERS;

--Get orders placed in the last 3 days
SELECT ORDER_ID, CUSTOMER_NAME, ORDER_DATE 
FROM SOURCE_ORDERS
WHERE ORDER_DATE >= CURRENT_DATE-3;

--Get only delivered orders
SELECT ORDER_ID, CUSTOMER_NAME, PRODUCT_NAME,STATUS
FROM SOURCE_ORDERS
WHERE STATUS = 'DELIVERED';

