--How to find out duplicates, what are the ways

--METHOD 1 - Group by + having
SELECT ORDER_ID, COUNT(*) AS CNT
FROM FACT_ORDERS
GROUP BY ORDER_ID
HAVING COUNT(*) > 1;

--METHOD 2 - ROW NUMBER
SELECT * FROM(
SELECT *,
ROW_NUMBER() OVER(PARTITION BY ORDER_ID ORDER BY CREATED_TS DESC) AS RN
FROM FACT_ORDERS) AS T
WHERE RN > 1;

--Delete Duplicates once Identified
DELETE FROM FACT_ORDERS
WHERE CREATED_TS IN (
    SELECT CREATED_TS
    FROM (
        SELECT CREATED_TS,
        ROW_NUMBER() OVER(PARTITION BY ORDER_ID ORDER BY CREATED_TS DESC) AS RN
        FROM FACT_ORDERS
    ) T
    WHERE RN > 1
);

