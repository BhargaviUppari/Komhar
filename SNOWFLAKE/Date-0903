--Convert date from MM-DD-YYYY to DD-MON-YYYY format
SELECT TO_VARCHAR(CREATED_DATE,'DD-MON-YYYY'),
FROM DIM_CUSTOMER;

--Find top 3 customers per city based on total order amount
SELECT *
FROM(
    SELECT C.CITY,C.CUSTOMER_NAME,SUM(F.AMOUNT) AS TOTAL_REVENUE,
    ROW_NUMBER() OVER (PARTITION BY C.CITY ORDER BY SUM(F.AMOUNT) DESC) AS RN
    FROM DIM_CUSTOMER C
    JOIN FACT_ORDERS F
    ON C.CUSTOMER_ID = F.CUSTOMER_ID
    GROUP BY C.CITY, C.CUSTOMER_NAME
) T
WHERE RN <= 3
ORDER BY CITY, TOTAL_REVENUE DESC;

SELECT C.CITY,C.CUSTOMER_NAME,SUM(F.AMOUNT) AS TOTAL_REVENUE,
    FROM DIM_CUSTOMER C
    JOIN FACT_ORDERS F
    ON C.CUSTOMER_ID = F.CUSTOMER_ID
    GROUP BY C.CITY, C.CUSTOMER_NAME
    QUALIFY ROW_NUMBER() OVER (PARTITION BY C.CITY ORDER BY SUM(F.AMOUNT) DESC) <=3;

--Retrieve latest order placed by each customer
SELECT CUSTOMER_ID, ORDER_ID, ORDER_DATE,
FROM FACT_ORDERS
QUALIFY ROW_NUMBER() OVER (PARTITION BY CUSTOMER_ID ORDER BY ORDER_DATE DESC)=1;

--Identify customers who never placed any orders
SELECT C.CUSTOMER_ID, C.CUSTOMER_NAME,
FROM DIM_CUSTOMER C
LEFT JOIN FACT_ORDERS F
ON C.CUSTOMER_ID = F.CUSTOMER_ID
WHERE F.CUSTOMER_ID IS NULL;

--Calculate monthly revenue from FACT_ORDERS
--per month
SELECT  DATE_TRUNC('MONTH',ORDER_DATE) AS MONTH,
SUM(AMOUNT) AS TOTAL_REVENUE,
FROM FACT_ORDERS
GROUP BY MONTH;

-- per week
SELECT DATE_TRUNC('WEEK',ORDER_DATE) AS WEEKLY,
SUM(AMOUNT) AS TOTAL_REVENUE,
FROM FACT_ORDERS
GROUP BY WEEKLY;

--Compute running total of order amount per customer ordered by date
SELECT CUSTOMER_ID,ORDER_DATE,AMOUNT,
       SUM(AMOUNT) OVER (PARTITION BY CUSTOMER_ID ORDER BY ORDER_DATE DESC)AS RUNNING_TOTAL
       FROM FACT_ORDERS
       ORDER BY CUSTOMER_ID;

--Detect duplicate ORDER_ID values in FACT_ORDERS
SELECT ORDER_ID,COUNT(*) AS COUNT
FROM FACT_ORDERS
GROUP BY ORDER_ID
HAVING COUNT(*)>1;

--Demonstrate difference between UNION and UNION ALL using order datasets
    --Union = Combines results and removes duplicate rows
    --        Performs DISTINCT automatically
        
    --Union All = Combines results and keeps duplicate rows
    --            Faster than UNION because it does not remove duplicates     
SELECT CUSTOMER_ID FROM DIM_CUSTOMER
UNION
SELECT CUSTOMER_ID FROM FACT_ORDERS
ORDER BY CUSTOMER_ID;

SELECT CUSTOMER_ID FROM DIM_CUSTOMER
UNION ALL
SELECT CUSTOMER_ID FROM FACT_ORDERS
ORDER BY CUSTOMER_ID;

--LAG and LEAD are window functions used to access values from previous or next rows without using joins
--LAG() gets the previous row value
--LEAD() gets the next row value

-- Find previous order amount per customer using LAG
SELECT CUSTOMER_ID, ORDER_DATE, AMOUNT,
LAG(AMOUNT) OVER (ORDER BY CUSTOMER_ID) AS PREVIOUS_AMOUNT
FROM FACT_ORDERS;

--Find next order amount per customer using LEAD  
SELECT CUSTOMER_ID,ORDER_DATE,AMOUNT,
LEAD(AMOUNT) OVER (ORDER BY CUSTOMER_ID) AS NEXT_AMOUNT
FROM FACT_ORDERS;

--Identify orders where amount is greater than the customer's average order amount
SELECT ORDER_ID, CUSTOMER_ID, AMOUNT
FROM(
SELECT ORDER_ID,CUSTOMER_ID,AMOUNT,
       AVG(AMOUNT) OVER(PARTITION BY CUSTOMER_ID) AS AVG_AMOUNT
FROM FACT_ORDERS
) T
WHERE AMOUNT > AVG_AMOUNT;

--Find the highest order amount per city
SELECT C.CITY,MAX(AMOUNT) AS HIGHEST_AMOUNT
FROM DIM_CUSTOMER C
JOIN FACT_ORDERS F
ON C.CUSTOMER_ID = F.CUSTOMER_ID
GROUP BY CITY
ORDER BY MAX(AMOUNT) DESC;

--Calculate number of days between consecutive orders for each customer
SELECT CUSTOMER_ID, ORDER_ID, ORDER_DATE,
       LAG(ORDER_DATE) OVER(PARTITION BY CUSTOMER_ID ORDER BY ORDER_DATE) AS PREVIOUS_ORDER_DATE,
       DATEDIFF(DAY,
                LAG(ORDER_DATE) OVER(PARTITION BY CUSTOMER_ID ORDER BY ORDER_DATE),
                ORDER_DATE) AS DAYS_BETWEEN_ORDERS
FROM FACT_ORDERS;

--Count number of orders by STATUS 
SELECT STATUS, COUNT(*) AS COUNT
FROM FACT_ORDERS
GROUP BY STATUS;

--Categorize customers into Platinum, Gold, Silver based on revenue
SELECT CUSTOMER_ID, SUM(AMOUNT) AS TOTAL_REVENUE,
CASE
    WHEN SUM(AMOUNT) >= 1500 THEN 'PLATINUM'
    WHEN SUM(AMOUNT) >= 1000 THEN 'GOLD'
    ELSE 'SILVER'
END AS CUSTOMER_CATEGORY    
FROM FACT_ORDERS
GROUP BY CUSTOMER_ID;

--Retrieve first and last order date per customer
SELECT CUSTOMER_ID,
MIN(ORDER_DATE) AS FIRST_ORDER_DATE,
MAX(ORDER_DATE) AS LAST_ORDER_DATE,
FROM FACT_ORDERS
GROUP BY CUSTOMER_ID;

--Find highest order placed each day 
SELECT ORDER_DATE, MAX(AMOUNT) AS HIGHER_ORDER,
FROM FACT_ORDERS
GROUP BY ORDER_DATE
ORDER BY ORDER_DATE ASC;

--List customers who placed more than 5 orders 
SELECT CUSTOMER_ID,
       COUNT(ORDER_ID) AS TOTAL_ORDERS
FROM FACT_ORDERS
GROUP BY CUSTOMER_ID
HAVING COUNT(ORDER_ID) > 5;

--Retrieve orders placed in the last 7 days
SELECT ORDER_ID, CUSTOMER_ID, ORDER_DATE
FROM FACT_ORDERS
WHERE ORDER_DATE >= CURRENT_DATE-7;

SELECT ORDER_ID, CUSTOMER_ID, ORDER_DATE
FROM FACT_ORDERS
WHERE ORDER_DATE >=DATEADD(DAY, -7, CURRENT_DATE);

--From multiple records per ORDER_ID, return the latest status using CDC logic
SELECT *FROM STG_ORDERS;

SELECT ORDER_ID, STATUS
FROM(
SELECT ORDER_ID, STATUS,
       ROW_NUMBER() OVER(PARTITION BY ORDER_ID ORDER BY UPDATED_TS DESC) AS RN
FROM FACT_ORDERS
) T
WHERE RN = 1;

/*HAVING is used to filter aggregated results after GROUP BY,
while window functions are used to perform calculations across rows without collapsing the dataset*/

