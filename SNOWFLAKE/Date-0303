1) Find the latest order per customer

SELECT *
FROM(
    SELECT CUSTOMER_ID,ORDER_ID, ORDER_DATE, AMOUNT,
    ROW_NUMBER() OVER (PARTITION BY CUSTOMER_ID ORDER BY ORDER_DATE DESC) AS RN
    FROM  FACT_ORDERS)
    WHERE (RN = 1);

    PARTITION BY - Divide data into groups
    ORDER BY	-  Decide ranking inside group
    ROW_NUMBER  -  Assign numbers

2) CTE-Based Aggregation:-
  (Common Table Expression)
    First calculate aggregated data inside a CTE
    Then use that aggregated result in the main query
 It is a temporary result set defined using WITH

(CTE) is a temporary result set in SQL that you can reference within a single query
You cannot use the CTE outside the query

    ALTER TABLE DIM_CUSTOMER
    ADD UPDATED_DATE TIMESTAMP;

    MERGE INTO DIM_CUSTOMER DC
    USING (
        WITH CUSTOMER_REVENUE AS(
            SELECT CUSTOMER_ID, SUM(AMOUNT) AS TOTAL_REVENUE
            FROM FACT_ORDERS
            GROUP BY CUSTOMER_ID
        ),
        
        CUSTOMER_CATEGORY AS(
            SELECT CUSTOMER_ID,
                TOTAL_REVENUE,
                CASE
                    WHEN TOTAL_REVENUE > 50000 THEN 'PLATINUM'
                    WHEN TOTAL_REVENUE BETWEEN 20000 AND 50000 THEN 'GOLD'
                    ELSE 'SILVER'
                    END AS CUSTOMER_TYPE
                FROM CUSTOMER_REVENUE    
            )
            SELECT* FROM CUSTOMER_CATEGORY
            ) CC
            
            ON DC.CUSTOMER_ID = CC.CUSTOMER_ID
        
            WHEN MATCHED THEN 
            UPDATE SET 
                DC.CUSTOMER_TYPE = CC.CUSTOMER_TYPE,
                DC.UPDATED_DATE= CURRENT_TIMESTAMP()
        
            WHEN NOT MATCHED THEN
            INSERT(CUSTOMER_ID, CUSTOMER_TYPE, UPDATED_DATE) 
            VALUES (CC.CUSTOMER_ID, CC.CUSTOMER_TYPE, CURRENT_TIMESTAMP());


    SELECT * FROM DIM_CUSTOMER;

 ##Target Table = DIM_CUSTOMER
 ##CUSTOMER_REVENUE (CTE)
   CUSTOMER_CATEGORY (CTE)
##Source Table = CUSTOMER_CATEGORY (CTE result)

        FACT_ORDERS
            ↓
        CUSTOMER_REVENUE  (SUM of AMOUNT)
            ↓
        CUSTOMER_CATEGORY (PLATINUM / GOLD / SILVER classification)
            ↓
        MERGE
            ↓
        DIM_CUSTOMER  ← Target Table


b. Generate a Customer Performance Report that shows: 

    WITH CUSTOMER_REVENUE AS
(
    -- Calculate total revenue per customer
    SELECT 
        C.CUSTOMER_ID, C.CUSTOMER_NAME, C.CITY,
        SUM(F.AMOUNT) AS TOTAL_REVENUE
    FROM DIM_CUSTOMER C
    JOIN FACT_ORDERS F
        ON C.CUSTOMER_ID = F.CUSTOMER_ID
    GROUP BY 
        C.CUSTOMER_ID,C.CUSTOMER_NAME,C.CITY
),

LATEST_ORDER AS
(
    -- Get latest order per customer
    SELECT
        CUSTOMER_ID,
        AMOUNT AS LATEST_ORDER_AMOUNT,
        ROW_NUMBER() OVER(
            PARTITION BY CUSTOMER_ID
            ORDER BY ORDER_DATE DESC
        ) AS RN
    FROM FACT_ORDERS
),

FINAL_REPORT AS
(
    SELECT
        CR.CUSTOMER_NAME,
        CR.CITY,
        CR.TOTAL_REVENUE,

        CASE
            WHEN CR.TOTAL_REVENUE >= 10000 THEN 'HIGH'
            WHEN CR.TOTAL_REVENUE >= 5000 THEN 'MEDIUM'
            ELSE 'LOW'
        END AS REVENUE_CATEGORY,

        LO.LATEST_ORDER_AMOUNT,

        RANK() OVER(
            PARTITION BY CR.CITY
            ORDER BY CR.TOTAL_REVENUE DESC
        ) AS CUSTOMER_RANK

    FROM CUSTOMER_REVENUE CR
    JOIN LATEST_ORDER LO
        ON CR.CUSTOMER_ID = LO.CUSTOMER_ID
    WHERE LO.RN = 1
)

SELECT *
FROM FINAL_REPORT;
We calculate total revenue first, then apply ranking.

PARTITION BY → creates groups
ORDER BY → decides ranking inside group
RANK() → assigns position 

