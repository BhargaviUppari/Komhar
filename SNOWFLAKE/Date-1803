CREATE OR REPLACE PROCEDURE SCD1_LOAD()
RETURNS STRING 
LANGUAGE SQL
AS

BEGIN

     UPDATE DIM_CUSTOMERS D    --update
     SET NAME = S.NAME,
         CITY = S.CITY
     FROM STG_CUSTOMERS S
     WHERE D.CUSTOMER_ID = S.CUSTOMER_ID;

    INSERT INTO DIM_CUSTOMERS (CUSTOMER_ID, NAME, CITY)
    SELECT S.CUSTOMER_ID, S.NAME, S.CITY
    FROM STG_CUSTOMERS S
    LEFT JOIN DIM_CUSTOMERS D
    ON S.CUSTOMER_ID = D.CUSTOMER_ID
    WHERE D.CUSTOMER_ID IS NULL;
    
    RETURN 'DONE';
    
END;


CALL SCD1_LOAD();

SELECT * 
FROM DIM_CUSTOMERS
ORDER BY CUSTOMER_ID;

