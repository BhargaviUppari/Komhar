MERGE INTO FACT_ORDERS F
USING STG_ORDERS S
ON F.ORDER_ID = S.ORDER_ID

    WHEN MATCHED THEN
        UPDATE SET
            F.AMOUNT = S.AMOUNT,
            F.STATUS = S.STATUS,
            F.UPDATED_TS = CURRENT_TIMESTAMP()

    WHEN NOT MATCHED THEN
        INSERT (ORDER_ID, CUSTOMER_ID, ORDER_DATE, AMOUNT, STATUS, CREATED_TS, UPDATED_TS)
        VALUES (S.ORDER_ID, S.CUSTOMER_ID, S.ORDER_DATE, S.AMOUNT,
        S.STATUS, CURRENT_TIMESTAMP(), CURRENT_TIMESTAMP());
        
