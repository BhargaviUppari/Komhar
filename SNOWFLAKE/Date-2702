MERGE INTO FACT_ORDERS F
USING (
    SELECT
        RAW_XML:"order":"order_id"::INT        AS ORDER_ID,
        RAW_XML:"order":"customer_id"::INT     AS CUSTOMER_ID,
        RAW_XML:"order":"amount"::NUMBER(10,2) AS AMOUNT,
        RAW_XML:"order":"status"::STRING       AS STATUS
    FROM STG_ORDERS_XML
) S
ON F.ORDER_ID = S.ORDER_ID

WHEN MATCHED THEN
    UPDATE SET
        F.AMOUNT = S.AMOUNT,
        F.STATUS = S.STATUS,
        F.UPDATED_TS = CURRENT_TIMESTAMP()

WHEN NOT MATCHED THEN
    INSERT (ORDER_ID, CUSTOMER_ID, ORDER_DATE, AMOUNT, STATUS, CREATED_TS, UPDATED_TS)
    VALUES (S.ORDER_ID, S.CUSTOMER_ID, CURRENT_DATE(), S.AMOUNT, S.STATUS, CURRENT_TIMESTAMP(), CURRENT_TIMESTAMP());

