CREATE or replace FILE FORMAT XML_FORMAT
TYPE = XML;

CREATE or replace STAGE XML_STAGE
FILE_FORMAT = XML_FORMAT;

CREATE or replace TABLE STG_ORDERS_XML (
    RAW_XML VARIANT
);

