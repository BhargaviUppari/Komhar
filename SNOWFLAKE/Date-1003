USE DATABASE SNOWFLAKE_DB;
USE SCHEMA PRACTICE_S;

--Find total orders per customer using CTE
WITH TOTAL_ORDERS AS(
SELECT CUSTOMER_ID, COUNT(ORDER_ID) AS TOTALORDERS
FROM FACT_ORDERS
GROUP BY CUSTOMER_ID
)

SELECT*FROM TOTAL_ORDERS;

--Find customers whose total spending > 500 using CTE
WITH TOTAL_SPENDING AS(
SELECT CUSTOMER_ID, SUM(AMOUNT) AS TOTAL_AMOUNT
FROM FACT_ORDERS
GROUP BY CUSTOMER_ID
)

SELECT*FROM TOTAL_SPENDING
WHERE TOTAL_AMOUNT > 500;

--Find orders placed in the last 7 days using CTE
WITH RECENTORDERS AS (
SELECT*
    FROM FACT_ORDERS
    WHERE ORDER_DATE >= CURRENT_DATE - 7
)

SELECT*FROM RECENTORDERS;

SELECT* FROM FACT_ORDERS;

--Remove Duplicate Records (Latest Only)
WITH DUPLICATES AS (
    SELECT *,
           ROW_NUMBER() OVER (PARTITION BY CUSTOMER_ID ORDER BY CREATED_DATE DESC) AS RN
    FROM DIM_CUSTOMER
)

SELECT *
FROM DUPLICATES
WHERE RN = 1;

SELECT * FROM DIM_CUSTOMER;

--Find Customers Who Never Ordered
WITH ORDERED_CUSTOMERS AS (
    SELECT DISTINCT CUSTOMER_ID
    FROM FACT_ORDERS
)
SELECT *
FROM DIM_CUSTOMER
WHERE CUSTOMER_ID NOT IN (SELECT CUSTOMER_ID FROM ORDERED_CUSTOMERS);

--Identify First Order of Each Customer
WITH FIRST_ORDER AS (
    SELECT CUSTOMER_ID,
           ORDER_DATE,
           ROW_NUMBER() OVER (PARTITION BY CUSTOMER_ID ORDER BY ORDER_DATE) AS RN
    FROM FACT_ORDERS
)
SELECT CUSTOMER_ID, ORDER_DATE
FROM FIRST_ORDER
WHERE RN = 1;